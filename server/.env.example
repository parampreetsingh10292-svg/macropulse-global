# ─────────────────────────────────────────────────────────────
# MacroPulse Global — Backend Environment
# Copy this file to ".env" and fill in any keys you have.
# The app RUNS WITHOUT ANY KEYS using free no-key providers +
# bundled validated datasets. Keys unlock live quotes & higher limits.
# ─────────────────────────────────────────────────────────────

PORT=8787
NODE_ENV=development

# Allowed frontend origin (Vite dev server by default)
CLIENT_ORIGIN=http://localhost:5173

# ── Market data (stock indices, quotes, commodities) ──
# https://twelvedata.com  (free Basic tier ~800 req/day)
TWELVE_DATA_KEY=

# https://site.financialmodelingprep.com  (free 250 req/day) — indices + calendar
FMP_KEY=

# https://metals.dev  (optional, precious metals; 100 req/mo free)
METALS_DEV_KEY=

# ── Macro (recent nowcasts; World Bank is used with no key) ──
# https://tradingeconomics.com  (trial key, optional)
TE_KEY=

# https://fred.stlouisfed.org  (free, optional — central bank rates)
FRED_KEY=

# ── News & geopolitics ──
# https://newsapi.org  (free 100 req/day)
NEWS_API_KEY=

# https://gnews.io  (free fallback, optional)
GNEWS_KEY=

# Cache TTLs (seconds) — tune to stay within free tiers
CACHE_TTL_QUOTES=60
CACHE_TTL_FX=300
CACHE_TTL_COMMODITIES=300
CACHE_TTL_MACRO=86400
CACHE_TTL_NEWS=900
CACHE_TTL_CALENDAR=21600
